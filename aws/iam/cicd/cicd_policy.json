{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "LambdaUpdateCode",
      "Effect": "Allow",
      "Action": ["lambda:UpdateFunctionCode"],
      "Resource": "arn:aws:lambda:sa-east-1:580148408154:function:*"
    },
    {
      "Sid": "GlueUpdateJob",
      "Effect": "Allow",
      "Action": ["glue:UpdateJob", "glue:GetJob"],
      "Resource": "*"
    },
    {
      "Sid": "S3ArtifactsBucket",
      "Effect": "Allow",
      "Action": ["s3:PutObject", "s3:GetObject", "s3:DeleteObject", "s3:ListBucket"],
      "Resource": [
        "arn:aws:s3:::bws-artifacts-sae1-prd",
        "arn:aws:s3:::bws-artifacts-sae1-prd/*"
      ]
    }, 
    {
      "Sid": "TerraformAndIAM",
      "Effect": "Allow",
      "Action": [
        "states:*",
        "events:*",
        "iam:GetRole",
        "iam:CreateRole",
        "iam:PutRolePolicy",
        "iam:GetRolePolicy",
        "iam:DeleteRolePolicy",
        "iam:PassRole",
        "iam:ListAttachedRolePolicies",
        "iam:ListRolePolicies",
        "dynamodb:*"
      ],
      "Resource": "*"
    }
  ]
}
